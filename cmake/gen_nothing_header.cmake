# gen_nothing_header.cmake
#
# Converts a .so file to a C header with an embedded byte array.
# Usage: cmake -DINPUT_FILE=<path-to-libshadowhook_nothing.so>
#             -DOUTPUT_FILE=<path-to-nothing_embed.h>
#             -P gen_nothing_header.cmake

if(NOT INPUT_FILE)
    message(FATAL_ERROR "INPUT_FILE is required")
endif()

if(NOT OUTPUT_FILE)
    message(FATAL_ERROR "OUTPUT_FILE is required")
endif()

if(NOT EXISTS "${INPUT_FILE}")
    message(FATAL_ERROR "INPUT_FILE does not exist: ${INPUT_FILE}")
endif()

# Read the .so file as hex bytes
file(READ "${INPUT_FILE}" HEXBYTES HEX)

# Get file size
file(SIZE "${INPUT_FILE}" FILE_SIZE)

# Use just the filename (not the full build path) in the generated header
get_filename_component(INPUT_BASENAME "${INPUT_FILE}" NAME)

# Compute length of hex string
string(LENGTH "${HEXBYTES}" HEX_LEN)

# Build the C array
set(HEADER "// Auto-generated by gen_nothing_header.cmake\n")
string(APPEND HEADER "// Source: ${INPUT_BASENAME}\n")
string(APPEND HEADER "#ifndef NOTHING_EMBED_H\n")
string(APPEND HEADER "#define NOTHING_EMBED_H\n")
string(APPEND HEADER "\n")
string(APPEND HEADER "#include <stddef.h>\n")
string(APPEND HEADER "\n")
string(APPEND HEADER "static const unsigned char g_nothing_so_blob[] = {\n")

# Convert hex string to C array (16 bytes per line)
set(INDEX 0)
set(LINE "")
set(IS_FIRST_ON_LINE TRUE)
while(INDEX LESS HEX_LEN)
    # Extract two hex chars (one byte)
    math(EXPR NEXT_INDEX "${INDEX} + 2")
    string(SUBSTRING "${HEXBYTES}" ${INDEX} 2 BYTE)

    if(IS_FIRST_ON_LINE)
        set(IS_FIRST_ON_LINE FALSE)
    else()
        string(APPEND LINE ", ")
    endif()

    string(APPEND LINE "0x${BYTE}")

    math(EXPR COLUMN "${INDEX} / 2")
    math(EXPR COLUMN "${COLUMN} % 16")

    if(COLUMN EQUAL 15)
        string(APPEND LINE ",\n")
        string(APPEND HEADER "  ${LINE}")
        set(LINE "")
        set(IS_FIRST_ON_LINE TRUE)
    endif()

    set(INDEX ${NEXT_INDEX})
endwhile()

# Flush remaining bytes
if(NOT LINE STREQUAL "")
    string(APPEND LINE "\n")
    string(APPEND HEADER "  ${LINE}")
endif()

string(APPEND HEADER "};\n")
string(APPEND HEADER "\n")
string(APPEND HEADER "static const size_t g_nothing_so_size = ${FILE_SIZE};\n")
string(APPEND HEADER "\n")
string(APPEND HEADER "#endif // NOTHING_EMBED_H\n")

# Write output
file(WRITE "${OUTPUT_FILE}" "${HEADER}")

message(STATUS "Generated nothing embed header: ${OUTPUT_FILE}")
message(STATUS "  Input size: ${FILE_SIZE} bytes")
message(STATUS "  Output: ${OUTPUT_FILE}")
